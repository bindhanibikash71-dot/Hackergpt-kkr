# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# OPENROUTER_API_KEY: Required for AI API model access.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# JWT_SECRET: For auth.
JWT_SECRET="MY_JWT_SECRET"

# CASHFREE_APP_ID/SECRET: Payment integration.
CASHFREE_APP_ID="MY_CASHFREE_APP_ID"
CASHFREE_SECRET_KEY="MY_CASHFREE_SECRET_KEY"
